<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- Header Status Bar -->
    <LinearLayout
        android:id="@+id/status_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1E1E1E"
        android:padding="8dp">

        <TextView
            android:id="@+id/tv_fps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FPS: --"
            android:textColor="#00FF00"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_cpu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CPU: --%"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_memory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MEM: --MB"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_storage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cache: 7d"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Main Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Left: Video Monitor & Logs (70%) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.7"
            android:orientation="vertical"
            android:background="#000000"
            android:padding="2dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/monitor_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:contentDescription="Video Monitor" />

                <!-- Overlay Text for Status -->
                <TextView
                    android:id="@+id/tv_overlay_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:padding="10dp"
                    android:text="SYSTEM READY"
                    android:textColor="#FFFF00"
                    android:background="#80000000"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recognition Events"
                android:textColor="#FFFFFF"
                android:background="#333333"
                android:padding="4dp"
                android:textStyle="bold"/>

            <ScrollView
                android:id="@+id/scroll_log"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="#111111"
                android:fillViewport="true">
                <TextView
                    android:id="@+id/tv_recognition_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#00FF00"
                    android:textSize="12sp"
                    android:padding="4dp"
                    android:text=""
                    android:fontFamily="monospace"/>
            </ScrollView>

        </LinearLayout>

        <!-- Right: Control Panel (30%) -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.3"
            android:background="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CONTROLS"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btn_start_stop"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="START MONITORING"
                    android:backgroundTint="#008000"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CAMERA SELECTION"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinner_cameras"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="#333333"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="OVERLAY"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <Switch
                    android:id="@+id/switch_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Show Status Bar"
                    android:textColor="#FFFFFF"
                    android:thumbTint="#00FF00"
                    android:trackTint="#444444"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MODE SELECTION"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/rg_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <RadioButton
                        android:id="@+id/rb_continuous"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Continuous"
                        android:textColor="#FFFFFF"
                        android:buttonTint="#00FF00"
                        android:checked="true"
                        android:padding="8dp"/>

                    <RadioButton
                        android:id="@+id/rb_motion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Motion Trigger"
                        android:textColor="#FFFFFF"
                        android:buttonTint="#00FF00"
                        android:padding="8dp"/>
                </RadioGroup>

                <Button
                    android:id="@+id/btn_register_face"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="REGISTER FACE"
                    android:backgroundTint="#444444"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btn_view_logs"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="VIEW LOGS"
                    android:backgroundTint="#444444"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tv_app_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status: Idle"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="20dp"/>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</LinearLayout>
