{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (Ninja, no OpenCV)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build_ci",
      "cacheVariables": {
        "RK_SKIP_OPENCV": "ON"
      }
    },
    {
      "name": "windows",
      "displayName": "Windows (VS 2022, OpenCV)",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64", "strategy": "set" },
      "binaryDir": "${sourceDir}/build_win",
      "cacheVariables": {
        "OPENCV_ROOT": "$env{OPENCV_ROOT}",
        "OPENCV_CONTRIB_ROOT": "$env{OPENCV_CONTRIB_ROOT}"
      }
    },
    {
      "name": "android",
      "displayName": "Android RK3288",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build_android_rk3288",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "armeabi-v7a",
        "ANDROID_PLATFORM": "android-21",
        "ANDROID_STL": "c++_static",
        "OPENCV_ROOT": "$env{OPENCV_ROOT}",
        "OPENCV_CONTRIB_ROOT": "$env{OPENCV_CONTRIB_ROOT}",
        "WITH_IPP": "OFF",
        "OPENCV_DOWNLOAD_IPPICV": "OFF",
        "WITH_FFMPEG": "OFF",
        "BUILD_LIST": "core,imgproc,imgcodecs,objdetect,features2d"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "windows",
      "configurePreset": "windows",
      "configuration": "Release"
    },
    {
      "name": "android",
      "configurePreset": "android"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "windows",
      "configurePreset": "windows",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    }
  ]
}
